{
  "manifest_version": 3,
  "name": "AudioVisual Reader",
  "version": "1.0",
  "description": "Аудиовизуальный ридер с TTS и фоновыми картинками",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "AudioVisual Reader"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["panel.css"],
    "run_at": "document_idle"
  }],
  "background": {
    "service_worker": "background.js"
  }
}
